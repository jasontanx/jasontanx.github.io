---
import BaseLayout from "./BaseLayout.astro";

interface Frontmatter {
  title: string;
  date: string;
  summary: string;
  tags?: string[];
}

const { frontmatter } = Astro.props as { frontmatter: Frontmatter };
const { title, date, summary, tags = [] } = frontmatter;

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={`${title} — Jason Tan`} description={summary}>
  <a href="/posts/" class="back-link">← All posts</a>
  <article class="post">
    <header class="post-header">
      <h1>{title}</h1>
      <p class="post-meta">
        <time datetime={date}>{formattedDate}</time>
      </p>
      {tags.length > 0 && (
        <div class="post-tags">
          {tags.map((t) => <span class="tag">{t}</span>)}
        </div>
      )}
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    border-bottom: none;
  }
  .back-link:hover {
    color: var(--color-accent);
  }
  .post-header {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--color-border);
  }
  .post-header h1 {
    margin-bottom: 12px;
  }
  .post-meta {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0 0 12px;
  }
  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .post-content :global(h2) {
    margin-top: 36px;
  }
  .post-content :global(p) {
    line-height: 1.7;
  }
  .post-content :global(pre) {
    background: var(--color-bg-alt);
    padding: 16px;
    border-radius: var(--radius);
    overflow-x: auto;
    border: 1px solid var(--color-border);
  }
  .post-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 16px;
    margin: 16px 0;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
